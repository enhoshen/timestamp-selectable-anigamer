{
  "manifest_version": 3,
  "name": "Selectable Video Time",
  "version": "1.0",
  "description": "Makes the video current time display selectable.",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://ani.gamer.com.tw/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ani.gamer.com.tw/animeVideo.php*"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
